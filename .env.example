# ─────────────────────────────────────────────────────────────
# AI API Generator — Environment Configuration
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# OpenAI (Responses API / Codex). If left empty, the app runs in
# MOCK mode and returns a realistic generated project locally so you
# can develop the full UX without an API key.
OPENAI_API_KEY=
# Model used for generation. Codex / gpt family recommended.
OPENAI_MODEL=gpt-4o-mini

# Auth — a long random string used to sign JWTs.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-use-a-long-random-string
# Access token lifetime (seconds) and refresh token lifetime (seconds).
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Public site URL (used in docs / metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000
